---
import InteriorLayout from "@/layouts/InteriorLayout.astro";
import obsidianfrog from "@/assets/images/illustrations/ranaobsidian.png";
import ts from "@/assets/icons/typescript.svg";
import py from "@/assets/icons/python.svg";
import expo from "@/assets/icons/expo.svg";
import nextjs from "@/assets/icons/nextjs.svg";
import ps from "@/assets/icons/photoshop.svg";
import react from "@/assets/icons/react.svg";
import ae from "@/assets/icons/aftereffects.svg";
import tailwind from "@/assets/icons/tailwind.svg";
import pw from "@/assets/icons/playwright.svg";
import astro from "@/assets/icons/astro.svg";
import php from "@/assets/icons/php.svg";
import gleam from "@/assets/icons/lucy.svg";
import flutterflow from "@/assets/icons/flutterflow.jpeg";
import wordpress from "@/assets/icons/wordpress.svg";
import yo from "@/assets/images/yo3.webp";

import moodle from "@/assets/icons/Moodle.svg";
import supabase from "@/assets/icons/supabase.svg";
import { Image } from "astro:assets";
import DuolingoWidget from "@/components/DuolingoWidget";
import type { DuolingoUser } from "@/components/DuolingoWidget";
import LastFmStats from "@/components/LastFmStats";

let duolingoData: DuolingoUser | null = null;
try {
  const res = await fetch(
    `https://www.duolingo.com/2017-06-30/users?username=${encodeURIComponent("agustn305652")}`
  );
  if (res.ok) {
    const json = await res.json();
    const u = json.users?.[0];
    if (u) {
      duolingoData = {
        username: u.username ?? "agustn305652",
        streak: u.streak ?? 0,
        totalXp: u.totalXp ?? 0,
        courses: u.courses ?? [],
      };
    }
  }
} catch (e) {
  console.error("Failed to fetch Duolingo data at build time", e);
}

---

<InteriorLayout title="Portfolio | Caracolaracol">

  <!-- ═══ HERO / INTRO ═══ -->
  <section>
    <h1>Introduction</h1>
    <p class="my-2">
      Hi! I'm Agustín Rojas, thank you for visiting my portfolio! You've
      gained access to a detailed archive of all of my works. Although you
      can encounter mostly my software development projects and
      collaborations, there is also a significant amount of artwork here.
    </p>
    <div class="flex justify-center my-6">
      <Image src={obsidianfrog} alt="frog obsidian" width={240} />
    </div>
  </section>

  <!-- ═══ ABOUT ME ═══ -->
  <section class="mt-6">
    <h1>About me</h1>
    <div class="grid grid-cols-[1fr_10rem] tablet:grid-cols-[1fr_16rem] laptop:grid-cols-[1fr_20rem] gap-4 tablet:gap-6 laptop:gap-10 mt-2">
      <div>
        <p class="my-2">
          I'm from Santiago, Chile. Here I work as a software engineer at
          <a class="text-ocre hover:text-cerise transition-colors" href="https://www.tipddy.cl/" target="_blank">Tipddy</a>,
          a great tech company with an awesome team that makes awesome
          products and services.
        </p>
        <p class="my-2">
          I enjoy building things and creating art with different materials
          each time. That will mean that when I want to create something, I
          don't mind spending a lot of time learning the technique first and
          then making the thing. I like the idea of never accommodating with
          just one way of creating art, by changing the way every time I feel
          like I already learned the skill.
        </p>
        <p class="my-2">
          I'm also into Organic farming, in fact I'm a member of an urban
          garden organization where I cultivate organic food in my own garden
          plots.
        </p>
      </div>

      <!-- Side column: photo + links + duolingo -->
      <div class="flex flex-col items-center gap-4 w-full">
        <Image
          class="rounded-2xl w-full border border-snow/10"
          src={yo}
          alt="yo"
        />
        <div class="flex flex-wrap justify-center gap-2">
          <a
            class="rounded-xl border border-snow/12 border-dotted px-3 py-1.5 text-sm text-timberwolf hover:text-ocre hover:border-ocre/40 transition-colors"
            href="https://github.com/Caracolaracol"
            target="_blank">Github</a>
          <a
            class="rounded-xl border border-snow/12 border-dotted px-3 py-1.5 text-sm text-timberwolf hover:text-ocre hover:border-ocre/40 transition-colors"
            href="https://www.linkedin.com/in/agustin-rojas-c4r4c01/"
            target="_blank">Linkedin</a>
          <a
            class="rounded-xl border border-snow/12 border-dotted px-3 py-1.5 text-sm text-timberwolf hover:text-ocre hover:border-ocre/40 transition-colors"
            href="https://www.instagram.com/caracolaracol/"
            target="_blank">Instagram</a>
          <a
            class="rounded-xl border border-snow/12 border-dotted px-3 py-1.5 text-sm text-timberwolf hover:text-ocre hover:border-ocre/40 transition-colors"
            href="https://docs.google.com/document/d/1p8NlNx_SESv5QeNiyZMEQTllUpHzBwEa34wesV15dyI/edit?usp=sharing"
            target="_blank">CV</a>
          <a
            class="rounded-xl border border-snow/12 border-dotted px-3 py-1.5 text-sm text-timberwolf hover:text-ocre hover:border-ocre/40 transition-colors"
            href="https://www.last.fm/es/user/agustinrojasm"
            target="_blank">Last.fm</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ MY STACK ═══ -->
  <section class="mt-2">
    <h1>My Stack</h1>
    <p class="pb-4">
      This is the set of tools or technologies that I currently use or prefer
      when I build my projects.
    </p>

    <div class="grid grid-cols-1 tablet:grid-cols-2 laptop:grid-cols-3 gap-4">
      <!-- Programming languages -->
      <div class="rounded-2xl border border-snow/12 border-dotted px-5 py-5 backdrop-blur-[2px]">
        <h2 class="font-chrono text-2xl mb-3">Programming languages</h2>
        <div class="flex flex-row flex-wrap gap-3">
          <Image src={ts} alt="typescript" class="rounded-md w-12 tablet:w-14" />
          <Image src={py} alt="python" class="rounded-md w-12 tablet:w-14" />
          <Image src={php} alt="php" class="rounded-md w-12 tablet:w-14" />
          <Image src={gleam} alt="gleam" class="rounded-md w-12 tablet:w-14" />
        </div>
      </div>

      <!-- Frameworks & Libraries -->
      <div class="rounded-2xl border border-snow/12 border-dotted px-5 py-5 backdrop-blur-[2px]">
        <h2 class="font-chrono text-2xl mb-3">Frameworks & Libraries</h2>
        <div class="flex flex-row flex-wrap gap-3">
          <Image src={react} alt="react" class="rounded-md w-12 tablet:w-14" />
          <Image src={expo} alt="expo" class="rounded-md w-12 tablet:w-14" />
          <Image src={nextjs} alt="nextjs" class="rounded-md w-12 tablet:w-14" />
          <Image src={tailwind} alt="tailwind" class="rounded-md w-12 tablet:w-14" />
          <Image src={pw} alt="playwright" class="rounded-md w-12 tablet:w-14" />
          <Image src={astro} alt="astro" class="rounded-md w-12 tablet:w-14" />
        </div>
      </div>

      <!-- Other tools -->
      <div class="rounded-2xl border border-snow/12 border-dotted px-5 py-5 backdrop-blur-[2px]">
        <h2 class="font-chrono text-2xl mb-3">Other tools</h2>
        <div class="flex flex-row flex-wrap gap-3">
          <Image src={supabase} alt="supabase" class="rounded-md w-12 tablet:w-14" />
          <Image src={ps} alt="photoshop" class="rounded-md w-12 tablet:w-14" />
          <Image src={ae} alt="after effects" class="rounded-md w-12 tablet:w-14" />
          <Image src={flutterflow} alt="flutterflow" class="rounded-md w-12 tablet:w-14" />
          <Image src={wordpress} alt="wordpress" class="rounded-md w-12 tablet:w-14" />
          <Image src={moodle} alt="moodle" class="rounded-md w-12 tablet:w-14" />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ STATS ═══ -->
  <section class="mt-6">
    <h1>Stats</h1>
    <div class="grid grid-cols-1 tablet:grid-cols-2 gap-4 mt-4">
      <LastFmStats client:idle username="agustinrojasm" />
      <DuolingoWidget data={duolingoData} />
    </div>
  </section>

</InteriorLayout>