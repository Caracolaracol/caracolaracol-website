---
import "@/styles/global.css";
import { ClientRouter } from "astro:transitions";

const { title } = Astro.props;
let pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body
    class={`w-[100dvw] h-[100dvh] background_noise_dark`}
  >
    <slot />
  </body>
</html>
<script is:inline>
  function applyBrowserNoiseBackground() {
    const isFirefox = navigator.userAgent.toLowerCase().includes("firefox");

    document.body.classList.toggle("background_noise_firefox", isFirefox);
    document.body.classList.toggle("background_noise_dark", true);
  }

  applyBrowserNoiseBackground();
  document.addEventListener("DOMContentLoaded", applyBrowserNoiseBackground);
  document.addEventListener("astro:page-load", applyBrowserNoiseBackground);
  document.addEventListener("astro:after-swap", applyBrowserNoiseBackground);
</script>
